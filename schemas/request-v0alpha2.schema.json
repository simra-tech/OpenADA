{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/schemas/request-v0alpha2.schema.json",
  "title": "OpenADA canonical request v0alpha2",
  "type": "object",
  "required": ["schema", "request_id", "canonical", "profile", "mapping", "capability_id", "inputs", "result_revision", "transport_policy", "context_name", "parameters", "extensions"],
  "properties": {
    "schema": {"const": "openada.request/v0alpha2"},
    "request_id": {"type": "string", "format": "uuid"},
    "canonical": {
      "type": "object",
      "required": ["algorithm", "sha256", "extensions"],
      "properties": {
        "algorithm": {"const": "openada.canonical-json/v1"},
        "sha256": {"$ref": "#/$defs/digest"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "profile": {"$ref": "#/$defs/exactResource"},
    "mapping": {"$ref": "#/$defs/exactResource"},
    "capability_id": {"$ref": "#/$defs/reverseDns"},
    "inputs": {"type": "array", "maxItems": 256, "items": {"$ref": "#/$defs/input"}},
    "result_revision": {"type": "string", "pattern": "^openada\\.result/v[0-9]+(?:(?:alpha|beta|rc)[1-9][0-9]*)?$", "maxLength": 120},
    "transport_policy": {
      "type": "object",
      "required": ["allowed", "timeout_ms", "extensions"],
      "properties": {
        "allowed": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"enum": ["local", "agent-session", "remote-job", "fake"]}},
        "timeout_ms": {"type": "integer", "minimum": 1, "maximum": 86400000},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "context_name": {"oneOf": [{"type": "string", "pattern": "^[a-z][a-z0-9-]{0,119}$"}, {"type": "null"}]},
    "parameters": {"type": "object", "maxProperties": 512},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reverseDns": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2,}$", "maxLength": 240},
    "version": {"type": "string", "pattern": "^v[0-9]+(?:(?:alpha|beta|rc)[1-9][0-9]*)?$", "maxLength": 32},
    "exactResource": {
      "type": "object",
      "required": ["identity", "revision", "sha256", "extensions"],
      "properties": {
        "identity": {"type": "string", "minLength": 1, "maxLength": 240},
        "revision": {"$ref": "#/$defs/version"},
        "sha256": {"$ref": "#/$defs/digest"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "input": {
      "type": "object",
      "required": ["role", "locator", "identity", "intent", "extensions"],
      "properties": {
        "role": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$", "maxLength": 120},
        "locator": {"type": "object"},
        "identity": {"oneOf": [{"$ref": "#/$defs/digest"}, {"type": "string", "minLength": 1, "maxLength": 240}]},
        "intent": {"enum": ["read", "mutate"]},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "extensions": {"type": "object", "maxProperties": 64, "propertyNames": {"pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"}, "additionalProperties": {"type": "object"}}
  },
  "additionalProperties": false
}
