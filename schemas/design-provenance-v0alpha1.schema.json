{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/schemas/design-provenance-v0alpha1.schema.json",
  "title": "OpenADA pinned public-design provenance v0alpha1",
  "type": "object",
  "required": [
    "$schema",
    "schema",
    "repository",
    "revision",
    "tree",
    "checkout_clean",
    "remote_url_verified",
    "license",
    "inputs",
    "extensions"
  ],
  "properties": {
    "$schema": {"const": "https://json-schema.org/draft/2020-12/schema"},
    "schema": {"const": "openada.design-provenance/v0alpha1"},
    "repository": {"type": "string", "format": "uri", "pattern": "^https://", "maxLength": 4096},
    "revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tree": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "checkout_clean": {"const": true},
    "remote_url_verified": {"const": true},
    "license": {"$ref": "#/$defs/sourceFile"},
    "inputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/sourceFile"}
    },
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "sourceFile": {
      "type": "object",
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/repositoryPath"},
        "bytes": {"type": "integer", "minimum": 1, "maximum": 1073741824},
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"},
      "additionalProperties": {"type": "object"}
    }
  }
}
