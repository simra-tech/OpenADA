{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/schemas/provider-bundle-v0alpha1.schema.json",
  "title": "OpenADA trusted provider bundle v0alpha1",
  "type": "object",
  "required": ["schema", "bundle", "contract_range", "source_distribution", "profiles", "assertions", "validators", "extensions"],
  "properties": {
    "schema": {"const": "openada.provider-bundle/v0alpha1"},
    "bundle": {
      "type": "object",
      "required": ["id", "version", "extensions"],
      "properties": {
        "id": {"$ref": "#/$defs/reverseDns"},
        "version": {"$ref": "#/$defs/version"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "contract_range": {
      "type": "object",
      "required": ["minimum", "maximum_exclusive", "extensions"],
      "properties": {
        "minimum": {"$ref": "#/$defs/version"},
        "maximum_exclusive": {"$ref": "#/$defs/version"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "source_distribution": {
      "type": "object",
      "required": ["name", "version", "extensions"],
      "properties": {
        "name": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,199}$"},
        "version": {"type": "string", "minLength": 1, "maxLength": 120},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "profiles": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/resource"}},
    "assertions": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/resource"}},
    "validators": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/validator"}},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reverseDns": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2,}$", "maxLength": 240},
    "version": {"type": "string", "pattern": "^v[0-9]+(?:(?:alpha|beta|rc)[1-9][0-9]*)?$", "maxLength": 32},
    "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]{1,1024}$"},
    "resource": {
      "type": "object",
      "required": ["identity", "revision", "sha256", "path", "extensions"],
      "properties": {
        "identity": {"type": "string", "minLength": 1, "maxLength": 240},
        "revision": {"$ref": "#/$defs/version"},
        "sha256": {"$ref": "#/$defs/digest"},
        "path": {"$ref": "#/$defs/path"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "validator": {
      "type": "object",
      "required": ["identity", "revision", "extensions"],
      "properties": {
        "identity": {"$ref": "#/$defs/reverseDns"},
        "revision": {"$ref": "#/$defs/version"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "extensions": {"type": "object", "maxProperties": 64, "propertyNames": {"pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"}, "additionalProperties": {"type": "object"}}
  },
  "additionalProperties": false
}
