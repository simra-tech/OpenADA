{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/schemas/result-v0alpha1.schema.json",
  "title": "OpenADA result v0alpha1",
  "type": "object",
  "required": [
    "schema",
    "operation",
    "tool",
    "execution",
    "engineering",
    "inputs",
    "artifacts",
    "diagnostics",
    "data",
    "provenance"
  ],
  "properties": {
    "schema": {
      "const": "openada.result/v0alpha1"
    },
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "oneOf": [
        {
          "$ref": "#/$defs/tool"
        },
        {
          "type": "null"
        }
      ]
    },
    "execution": {
      "$ref": "#/$defs/execution"
    },
    "engineering": {
      "$ref": "#/$defs/engineering"
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "data": {
      "type": "object"
    },
    "provenance": {
      "type": "object",
      "required": [
        "openada_version",
        "created_at",
        "host"
      ],
      "properties": {
        "openada_version": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
        },
        "host": {
          "$ref": "#/$defs/host"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "execution": {
            "properties": {
              "status": {
                "const": "completed"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "execution"
        ]
      },
      "then": {
        "properties": {
          "execution": {
            "properties": {
              "exit_code": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "tool": {
      "type": "object",
      "required": [
        "name",
        "path",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "status",
        "exit_code",
        "duration_ms",
        "command"
      ],
      "properties": {
        "status": {
          "enum": [
            "completed",
            "timed_out",
            "not_available",
            "invalid_request",
            "failed"
          ]
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        },
        "error": {
          "type": "string",
          "maxLength": 4000
        }
      },
      "additionalProperties": false
    },
    "engineering": {
      "type": "object",
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "fail",
            "unknown",
            "not_applicable"
          ]
        },
        "summary": {
          "type": "string",
          "maxLength": 4000
        }
      },
      "additionalProperties": false
    },
    "file": {
      "type": "object",
      "required": [
        "kind",
        "role",
        "path",
        "exists"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "exists": {
                "const": true
              }
            },
            "required": [
              "exists"
            ]
          },
          "then": {
            "required": [
              "bytes",
              "sha256"
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "bytes"
                  ]
                },
                {
                  "required": [
                    "sha256"
                  ]
                }
              ]
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "host": {
      "type": "object",
      "required": [
        "system",
        "machine",
        "python"
      ],
      "properties": {
        "system": {
          "type": "string"
        },
        "machine": {
          "type": "string"
        },
        "python": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": [
        "severity",
        "code",
        "message"
      ],
      "properties": {
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "maxLength": 4000
        },
        "hint": {
          "type": "string",
          "maxLength": 4000
        }
      },
      "additionalProperties": false
    }
  }
}
