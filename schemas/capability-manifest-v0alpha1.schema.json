{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/schemas/capability-manifest-v0alpha1.schema.json",
  "title": "OpenADA capability manifest v0alpha1",
  "type": "object",
  "required": ["schema", "provider_id", "manifest_revision", "capabilities", "extensions"],
  "properties": {
    "schema": {"const": "openada.capability-manifest/v0alpha1"},
    "provider_id": {"$ref": "#/$defs/reverseDns"},
    "manifest_revision": {"$ref": "#/$defs/version"},
    "capabilities": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/capability"}},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reverseDns": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2,}$", "maxLength": 240},
    "version": {"type": "string", "pattern": "^v[0-9]+(?:(?:alpha|beta|rc)[1-9][0-9]*)?$", "maxLength": 32},
    "feature": {
      "type": "object",
      "required": ["id", "maturity", "extensions"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 240},
        "maturity": {"enum": ["experimental", "structured", "workflow-validated", "signoff-reviewed"]},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "receipt": {
      "type": "object",
      "required": ["id", "sha256", "extensions"],
      "properties": {
        "id": {"$ref": "#/$defs/reverseDns"},
        "sha256": {"$ref": "#/$defs/digest"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "capability": {
      "type": "object",
      "required": ["id", "profile_sha256", "mapping_sha256", "features", "locator_revisions", "transport_revisions", "result_revisions", "tested_versions", "runtime_probe_policy", "conformance_receipts", "limitations", "non_advertised_features", "extensions"],
      "properties": {
        "id": {"$ref": "#/$defs/reverseDns"},
        "profile_sha256": {"$ref": "#/$defs/digest"},
        "mapping_sha256": {"$ref": "#/$defs/digest"},
        "features": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/feature"}},
        "locator_revisions": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "maxLength": 120}},
        "transport_revisions": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "maxLength": 120}},
        "result_revisions": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "maxLength": 120}},
        "tested_versions": {"type": "array", "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 200}},
        "runtime_probe_policy": {"enum": ["forbidden", "required", "optional"]},
        "conformance_receipts": {"type": "array", "maxItems": 128, "items": {"$ref": "#/$defs/receipt"}},
        "limitations": {"type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 4000}},
        "non_advertised_features": {"type": "array", "maxItems": 256, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 240}},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "extensions": {"type": "object", "maxProperties": 64, "propertyNames": {"pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"}, "additionalProperties": {"type": "object"}}
  },
  "additionalProperties": false
}
