{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/conformance/ihp-inverter/run.schema.json",
  "title": "OpenADA IHP conformance run metadata v0alpha1",
  "type": "object",
  "required": [
    "schema",
    "conformance_id",
    "conformance_manifest_sha256",
    "created_at",
    "design_revision",
    "image",
    "openada_checkout",
    "network"
  ],
  "properties": {
    "schema": {
      "const": "openada.conformance-run/v0alpha1"
    },
    "conformance_id": {
      "const": "ihp-inverter-drc-lvs"
    },
    "conformance_manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "design_revision": {
      "const": "133ecf657572e021b5921b5a1b7693abfb209623"
    },
    "image": {
      "type": "object",
      "required": [
        "reference",
        "id",
        "os",
        "architecture"
      ],
      "properties": {
        "reference": {
          "const": "hpretl/iic-osic-tools@sha256:fd38cb07a29d49d5f9720494cc4497cd8e8c80dfa06b4224d46447bc0f3c2ef0"
        },
        "id": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "os": {
          "const": "linux"
        },
        "architecture": {
          "const": "amd64"
        }
      },
      "additionalProperties": false
    },
    "openada_checkout": {
      "type": "object",
      "required": [
        "before",
        "after",
        "state_unchanged",
        "commit_exact"
      ],
      "properties": {
        "before": {
          "$ref": "#/$defs/checkoutState"
        },
        "after": {
          "$ref": "#/$defs/checkoutState"
        },
        "state_unchanged": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "commit_exact": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "network": {
      "const": "none during EDA execution"
    },
    "source_attestation": {"$ref": "#/$defs/sourceAttestation"}
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitObject": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "extensions": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"},
      "additionalProperties": {"type": "object"}
    },
    "sourceAttestation": {
      "type": "object",
      "required": ["receipt_class", "repository_revision", "repository_tree", "semantic_subject_sha256", "clean_before", "clean_after", "state_unchanged", "extensions"],
      "properties": {
        "receipt_class": {"enum": ["provisional", "release"]},
        "repository_revision": {"$ref": "#/$defs/gitObject"},
        "repository_tree": {"$ref": "#/$defs/gitObject"},
        "semantic_subject_sha256": {"$ref": "#/$defs/sha256"},
        "clean_before": {"type": "boolean"},
        "clean_after": {"type": "boolean"},
        "state_unchanged": {"type": "boolean"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "checkoutState": {
      "type": "object",
      "required": [
        "commit",
        "tracked_files_modified",
        "untracked_files_present",
        "working_tree_modified",
        "status_entry_count",
        "status_sha256"
      ],
      "properties": {
        "commit": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "tracked_files_modified": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "untracked_files_present": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "working_tree_modified": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "status_entry_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "status_sha256": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
