{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/conformance/orfs-ibex-synthesis-timing/run.schema.json",
  "title": "OpenADA ORFS Ibex synthesis/timing conformance run v0alpha1",
  "type": "object",
  "required": [
    "schema",
    "conformance_id",
    "chain_id",
    "conformance_manifest_sha256",
    "created_at",
    "design_revision",
    "design_tree",
    "upstream_revision",
    "input_inventory_sha256",
    "image",
    "tools",
    "openada_checkout",
    "network",
    "analysis_scope",
    "source_attestation",
    "native_artifacts"
  ],
  "properties": {
    "schema": {"const": "openada.conformance-run/v0alpha1"},
    "conformance_id": {"const": "orfs-ibex-synthesis-timing"},
    "chain_id": {"const": "openada.chain/orfs-ibex-synthesis-timing/v1"},
    "conformance_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "design_revision": {"const": "bea7dcd7be7f26d1328f6058b01cf42bf4352aa2"},
    "design_tree": {"const": "b0979ac02253b74d4e22b426d2e4827b1fbf5fc3"},
    "upstream_revision": {"const": "77d801001554cce8fe69e742e96539eecbe74425"},
    "input_inventory_sha256": {"$ref": "#/$defs/sha256"},
    "image": {
      "type": "object",
      "required": ["reference", "id", "os", "architecture"],
      "properties": {
        "reference": {"const": "hpretl/iic-osic-tools@sha256:fd38cb07a29d49d5f9720494cc4497cd8e8c80dfa06b4224d46447bc0f3c2ef0"},
        "id": {"const": "sha256:28573cfe204f66872c2aa7eb050692f7788ff0104eb733d950b790c72c253ceb"},
        "os": {"const": "linux"},
        "architecture": {"const": "amd64"}
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "object",
      "required": ["yosys", "abc", "opensta"],
      "properties": {
        "yosys": {
          "type": "object",
          "required": ["path", "version"],
          "properties": {
            "path": {"const": "/foss/tools/bin/yosys"},
            "version": {"const": "Yosys 0.66 (git sha1 86f2ddebc-dirty, g++ 13.3.0-6ubuntu2~24.04.1 -fPIC -O3)"}
          },
          "additionalProperties": false
        },
        "abc": {
          "type": "object",
          "required": ["path", "version", "bytes", "sha256"],
          "properties": {
            "path": {"const": "/foss/tools/yosys/bin/yosys-abc"},
            "version": {"const": "UC Berkeley, ABC 1.01 (compiled Jun 22 2026 11:38:08)"},
            "bytes": {"const": 21104032},
            "sha256": {"const": "8841cec163543e372becfd08940a4c5d03dc836cd1d3257d53525372d7f2b194"}
          },
          "additionalProperties": false
        },
        "opensta": {
          "type": "object",
          "required": ["path", "version"],
          "properties": {
            "path": {"const": "/foss/tools/openroad/bin/sta"},
            "version": {"const": "3.1.0"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "openada_checkout": {
      "type": "object",
      "required": ["before", "after", "state_unchanged", "commit_exact"],
      "properties": {
        "before": {"$ref": "#/$defs/checkoutState"},
        "after": {"$ref": "#/$defs/checkoutState"},
        "state_unchanged": {"type": "boolean"},
        "commit_exact": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "network": {"const": "none during EDA execution"},
    "analysis_scope": {"const": "single-corner synthesis-stage timing with ideal interconnect and no SPEF; not signoff"},
    "source_attestation": {"$ref": "#/$defs/sourceAttestation"},
    "native_artifacts": {
      "type": "array",
      "minItems": 19,
      "maxItems": 19,
      "items": {"$ref": "#/$defs/fileRecord"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitObject": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "extensions": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"},
      "additionalProperties": {"type": "object"}
    },
    "sourceAttestation": {
      "type": "object",
      "required": ["receipt_class", "repository_revision", "repository_tree", "semantic_subject_sha256", "clean_before", "clean_after", "state_unchanged", "extensions"],
      "properties": {
        "receipt_class": {"enum": ["provisional", "release"]},
        "repository_revision": {"$ref": "#/$defs/gitObject"},
        "repository_tree": {"$ref": "#/$defs/gitObject"},
        "semantic_subject_sha256": {"$ref": "#/$defs/sha256"},
        "clean_before": {"type": "boolean"},
        "clean_after": {"type": "boolean"},
        "state_unchanged": {"type": "boolean"},
        "extensions": {"$ref": "#/$defs/extensions"}
      },
      "additionalProperties": false
    },
    "fileRecord": {
      "type": "object",
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "pattern": "^(?:synthesis|timing|negative)/[A-Za-z0-9._-]+$"},
        "bytes": {"type": "integer", "minimum": 0, "maximum": 536870912},
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "checkoutState": {
      "type": "object",
      "required": ["commit", "tracked_files_modified", "untracked_files_present", "working_tree_modified", "status_entry_count", "status_sha256"],
      "properties": {
        "commit": {"oneOf": [{"type": "string", "pattern": "^[0-9a-f]{40}$"}, {"type": "null"}]},
        "tracked_files_modified": {"type": ["boolean", "null"]},
        "untracked_files_present": {"type": ["boolean", "null"]},
        "working_tree_modified": {"type": ["boolean", "null"]},
        "status_entry_count": {"type": ["integer", "null"], "minimum": 0},
        "status_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}
      },
      "additionalProperties": false
    }
  }
}
