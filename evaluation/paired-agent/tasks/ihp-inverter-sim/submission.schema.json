{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/simra-tech/OpenADA/main/evaluation/paired-agent/tasks/ihp-inverter-sim/submission.schema.json",
  "title": "OpenADA paired IHP inverter evaluation submission v0alpha1",
  "type": "object",
  "required": [
    "schema",
    "task_id",
    "status",
    "process_completed",
    "summary",
    "tools",
    "inputs",
    "artifacts",
    "limitations"
  ],
  "properties": {
    "schema": {
      "const": "openada.eval.submission/v0alpha1"
    },
    "task_id": {
      "const": "ihp-inverter-xschem-ngspice-paired"
    },
    "status": {
      "enum": ["pass", "fail", "unknown"]
    },
    "process_completed": {
      "type": ["boolean", "null"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "tools": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/tool"}
    },
    "inputs": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/input"}
    },
    "artifacts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/artifact"}
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "tool": {
      "type": "object",
      "required": ["name", "path", "version", "binary_sha256"],
      "properties": {
        "name": {"enum": ["xschem", "ngspice"]},
        "path": {
          "type": "string",
          "pattern": "^/[^\\u0000]*$",
          "maxLength": 4096
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "binary_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "input": {
      "type": "object",
      "required": ["role", "path", "bytes", "sha256"],
      "properties": {
        "role": {
          "enum": [
            "schematic",
            "xschem-rcfile",
            "pdk-revision",
            "ngspice-init",
            "ngspice-system-init"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/[^\\u0000]*$",
          "maxLength": 4096
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 536870912
        },
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["role", "path", "bytes", "sha256"],
      "properties": {
        "role": {
          "enum": ["generated-netlist", "simulation-raw", "simulation-log"]
        },
        "path": {
          "enum": [
            "work/inverter_tb.spice",
            "work/test_inverter.raw",
            "evidence/simulation/inverter_tb.log"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 536870912
        },
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    }
  }
}
